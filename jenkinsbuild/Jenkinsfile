pipeline {
  agent {
    kubernetes {
      label 'podman-agent'
      yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: podman
    image: quay.io/podman/stable:latest
    command:
    - cat
    tty: true
    securityContext:
      privileged: true
"""
    }
  }

  environment {
    REGISTRY   = "quay.io"
    IMAGE_REPO = "quay.io/<your-quay-username>/bck-04-nodejs"
    IMAGE_TAG  = "${env.BUILD_NUMBER}"
  }

  stages {

    stage('Checkout jenkinsbuild branch') {
      steps {
        container('podman') {
          git branch: 'jenkinsbuild',
              url: 'https://github.com/arjun0451/samplerepo.git'
        }
      }
    }

    stage('Login to Quay') {
      steps {
        container('podman') {
          withCredentials([usernamePassword(
            credentialsId: 'quay-cred',
            usernameVariable: 'QUAY_USER',
            passwordVariable: 'QUAY_PASS'
          )]) {
            sh '''
              podman login -u $QUAY_USER -p $QUAY_PASS $REGISTRY
            '''
          }
        }
      }
    }

    stage('Build Image') {
      steps {
        container('podman') {
          sh '''
            podman build -f Containerfile -t $IMAGE_REPO:$IMAGE_TAG .
          '''
        }
      }
    }

    stage('Push Image') {
      steps {
        container('podman') {
          sh '''
            podman push $IMAGE_REPO:$IMAGE_TAG
          '''
        }
      }
    }
  }

  post {
    success {
      echo "✅ Image pushed: $IMAGE_REPO:$IMAGE_TAG"
    }
    failure {
      echo "❌ Build failed"
    }
  }
}
